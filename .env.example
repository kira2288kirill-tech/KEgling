# Скопируй в .env и заполни. На Vercel/Netlify добавь те же имена в Settings → Environment Variables.

# Обязательно
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=KEgling_chop_BOT

# Опционально: куда слать копию заказа (число). Иначе один раз напиши боту /owner из своего Telegram
TELEGRAM_CHAT_ID=

# Опционально: тексты в профиле бота (иначе — значения по умолчанию в netlify/functions/config.js)
# TELEGRAM_BOT_DISPLAY_NAME=KEgling — магазин
# TELEGRAM_BOT_SHORT_DESC=Одежда KEgling: каталог и заказ в чате.
# TELEGRAM_BOT_LONG_DESC=Бот заказов KEgling…

# Опционально: 0 — отключить авто-обновление имени/описания бота при открытии сайта
# TELEGRAM_SYNC_PROFILE=0
